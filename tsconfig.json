{
  "compilerOptions": {
    "target": "es2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "downlevelIteration": true,
    "paths": {
      "@/components/*": [ "src/components/*" ],
      "@/domain/*": [ "src/domain/*" ],
      "@/hooks/*": [ "src/hooks/*" ],
      "@/services/*": [ "src/services/*" ],
      "@/providers/*": [ "src/providers/*" ],
      "@/state/*": [ "src/state/*" ],
      "@/images/*": [ "src/images/*" ],
      "@/lib/*": [ "src/lib/*" ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "custom-next-env.d.ts",
    "**/*.ts",
    "**/*.js",
    "**/*.tsx",
    "**/*.jsx",
    "**/*.mts",
    "**/*.mjs",
    "**/*.mtsx",
    "**/*.mjsx",
    "**/*.cts",
    "**/*.cjs",
    "**/*.ctsx",
    "**/*.cjsx",
    ".eslintrc.js",
    "jest.config.js",
    "jest.setup.js",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next/dev/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "next-env.d.ts",
    "public"
  ]
}